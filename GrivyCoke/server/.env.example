# Salin ke .env (atau set di dashboard host) lalu sesuaikan.
PORT=8787
# Origin game (untuk CORS). Produksi: domain tempat game di-host.
# GitHub Pages: https://eldranis12.github.io  ·  Grivy: https://ayo.coca-cola.co.id
CORS_ORIGIN=https://eldranis12.github.io
# Window tunggu multiplayer (detik) — dokumen Grivy: 15
JOIN_WINDOW_SECONDS=15
MAX_PLAYERS=4
GAME_SECONDS=180
# Grace kumpul skor setelah durasi game (detik)
RESULT_GRACE_SECONDS=25
# Umur sesi di memori sebelum dibersihkan (detik)
SESSION_TTL_SECONDS=300
