# Reverse proxy HTTPS -> Node server (127.0.0.1:8787).
# Game di GitHub Pages itu HTTPS, jadi server WAJIB HTTPS (kalau tidak,
# browser blokir fetch karena mixed content).
#
# Pasang: sudo cp nginx.conf.example /etc/nginx/sites-available/coke-mp
#         sudo ln -s /etc/nginx/sites-available/coke-mp /etc/nginx/sites-enabled/
#         sudo certbot --nginx -d mp.example.com     # dapat sertifikat TLS
#         sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name mp.example.com;              # ganti ke domain/subdomain-mu
    return 301 https://$host$request_uri;    # paksa HTTPS
}

server {
    listen 443 ssl;
    server_name mp.example.com;

    ssl_certificate     /etc/letsencrypt/live/mp.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mp.example.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# --- Alternatif: server jadi satu domain dengan API lain, di subpath ---
# Game harus set MP_URL_DEFAULT = 'https://api.example.com/coke-mp'
# dan prefix /coke-mp DIBUANG sebelum diteruskan (server kita pakai path
# absolut /session/*). Perhatikan trailing slash pada proxy_pass:
#
# location /coke-mp/ {
#     proxy_pass http://127.0.0.1:8787/;   # slash di akhir = strip /coke-mp/
#     proxy_set_header Host $host;
#     proxy_set_header X-Forwarded-Proto $scheme;
# }
